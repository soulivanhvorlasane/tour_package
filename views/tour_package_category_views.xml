<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tour_package_category_tree" model="ir.ui.view">
        <field name="name">tour.package.category.tree</field>
        <field name="model">tour.package.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_tour_package_category_form" model="ir.ui.view">
        <field name="name">tour.package.category.form</field>
        <field name="model">tour.package.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g., Adventure"/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Add description here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tour_package_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">tour.package.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tour_package_category" 
              name="Categories"
              parent="menu_tour_root" 
              action="action_tour_package_category"
              sequence="20"/>
</odoo>

