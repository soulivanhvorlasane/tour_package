<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tour_booking_form" model="ir.ui.view">
        <field name="name">tour.booking.form</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <form string="Tour Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('draft', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="calendar_id"/>
                            <field name="package_id"/>
                            <field name="partner_id"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="seats"/>
                            <field name="total_price"/>
                            <field name="payment_status" widget="badge" decoration-success="payment_status == 'confirmed'" decoration-warning="payment_status == 'pending'" decoration-info="payment_status == 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payment Details" name="payment_details">
                            <group string="Option A: Auto Payment (Card)">
                                <group>
                                    <field name="visa_card_name"/>
                                    <field name="visa_card_number"/>
                                </group>
                                <group>
                                    <field name="visa_expiry"/>
                                    <field name="visa_cvv"/>
                                </group>
                            </group>
                            <group string="Option B: QR Code Scan (Manual)">
                                <group>
                                    <field name="visa_account_name"/>
                                    <field name="visa_account_number"/>
                                </group>
                                <group>
                                    <field name="payment_date"/>
                                    <field name="payment_time" widget="float_time"/>
                                    <field name="transaction_file" filename="transaction_filename" widget="binary"/>
                                    <field name="transaction_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tour_booking_list" model="ir.ui.view">
        <field name="name">tour.booking.list</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <list string="Tour Bookings">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="calendar_id"/>
                <field name="seats"/>
                <field name="total_price"/>
                <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-info="state == 'draft'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_tour_booking_pivot" model="ir.ui.view">
        <field name="name">tour.booking.pivot</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <pivot string="Tour Bookings">
                <field name="package_id" type="row"/>
                <field name="state" type="col"/>
                <field name="seats" type="measure"/>
                <field name="total_price" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_tour_booking_calendar" model="ir.ui.view">
        <field name="name">tour.booking.calendar</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <calendar string="Booking Timeline"
                      date_start="date_start"
                      date_stop="date_end"
                      color="partner_id">
                <field name="package_id"/>
                <field name="partner_id"/>
                <field name="seats"/>
                <field name="payment_status"/>
            </calendar>
        </field>
    </record>

    <record id="action_tour_booking" model="ir.actions.act_window">
        <field name="name">Tour Bookings</field>
        <field name="res_model">tour.booking</field>
        <field name="view_mode">list,calendar,form,pivot</field>
    </record>
</odoo>
