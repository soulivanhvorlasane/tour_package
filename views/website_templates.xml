<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_tour_packages" name="Tour Packages">
        <t t-call="website.layout">
            <section class="container mt-5 mb-5">
                <div class="text-center mb-5">
                    <h1 class="fw-bold text-dark mb-3">Explore Our Tour Packages</h1>
                    <p class="text-muted lead" style="max-width: 700px; margin: 0 auto;">
                        Discover breathtaking destinations, unforgettable adventures, and hand-picked experiences designed just for you. Book your next journey today!
                    </p>
                </div>
                <div class="row">
                    <t t-foreach="packages" t-as="pkg">
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden" style="transition: transform 0.3s ease, box-shadow 0.3s ease;">
                                <!-- Image Section (Uniform size, cover) -->
                                <div class="position-relative bg-light" style="height: 240px;">
                                    <t t-if="pkg.cover_image">
                                        <img t-attf-src="data:image/png;base64,#{pkg.cover_image}" class="w-100 h-100" style="object-fit: cover;"/>
                                    </t>
                                    <t t-else="">
                                        <img src="/tour_package/static/images/default_cover.png" class="w-100 h-100" style="object-fit: cover; padding: 20px;"/>
                                    </t>
                                </div>
                                <!-- Card Body -->
                                <div class="card-body d-flex flex-column p-4">
                                    <h5 class="card-title fw-bold text-dark mb-2"><t t-esc="pkg.name"/></h5>
                                    
                                    <div class="card-text text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;" t-raw="pkg.description"/>
                                    
                                    <p class="mb-2 fw-bold text-success">
                                        <i class="fa fa-money me-2"></i>$<t t-esc="pkg.price"/> per person
                                    </p>
                                    
                                    <p class="mb-2 text-muted small" t-if="pkg.start_date">
                                        <i class="fa fa-calendar me-2"></i><t t-esc="pkg.start_date"/> to <t t-esc="pkg.end_date"/>
                                    </p>
                                    
                                    <p class="mb-4 text-muted small" t-if="pkg.availability_status">
                                        <i class="fa fa-info-circle me-2"></i>Status: <span class="badge bg-info"><t t-esc="pkg.availability_status"/></span>
                                    </p>
                                    
                                    <!-- Button pushed to bottom -->
                                    <div class="mt-auto">
                                        <a t-attf-href="/packages/#{pkg.id}/book" class="btn btn-primary w-100 rounded-pill fw-bold"> 
                                            More detail &amp; Book Now
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </section>
        </t>
    </template>
</odoo>
