<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="menu_tour_packages_website" model="website.menu">
        <field name="name">Tour Packages</field>
        <field name="url">/packages</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">50</field>
    </record>


    <template id="website_packages" name="Tour Packages">
        <t t-call="website.layout">
            <div class="container">
                <h1>Featured Tour Packages</h1>
                <div class="row">
                    <t t-foreach="packages" t-as="pkg">
                        <div class="col-md-4">
                            <div class="card mb-3">
                                <div class="card-body">
                                    <h3><t t-esc="pkg.name"/></h3>
                                    <p><t t-esc="pkg.description"/></p>
                                    <p>Price: <t t-esc="pkg.price"/></p>
                                    <a t-att-href="'/packages/%s/book' % pkg.id"
                                       class="btn btn-primary">Book Now</a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <record id="website_page_tour_packages" model="website.page">
        <field name="name">Tour Packages</field>
        <field name="url">/packages</field>
        <field name="is_published">True</field>
        <field name="view_id" ref="tour_package.website_packages"/>
    </record>

    <template id="tour_detail" name="Tour Detail">
        <t t-call="website.layout">
            <style>
                .tour-card-container {
                    width: 100%;
                    margin: 0 auto;
                }
                .tour-card {
                    border: 1px solid #e0e0e0;
                    border-radius: 12px;
                    padding: 10px;
                    background: #fff;
                    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                }
                .collage-main {
                    position: relative;
                    height: 250px;
                    margin-bottom: 5px;
                    border-radius: 8px;
                    overflow: hidden;
                }
                .collage-main img { width: 100%; height: 100%; object-fit: cover; }
                .play-btn {
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    width: 70px;
                    height: 70px;
                    background: rgba(0,0,0,0.6);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-size: 30px;
                    text-decoration: none !important;
                    border: 3px solid white;
                }
                .play-btn i {
                    margin-left: 5px;
                }
                .collage-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 5px;
                }
                .collage-grid img { width: 100%; height: 150px; object-fit: cover; border-radius: 4px; }
                
                .section-title {
                    display: flex;
                    align-items: center;
                    text-align: center;
                    color: #000;
                    font-weight: bold;
                    margin: 30px 20px 20px;
                    font-size: 18px;
                }
                .section-title::before, .section-title::after {
                    content: '';
                    flex: 1;
                    border-bottom: 1px solid #ddd;
                }
                .section-title::before { margin-right: 15px; }
                .section-title::after { margin-left: 15px; }
                
                .date-grid {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 15px;
                    margin: 0 20px 25px;
                }
                .date-radio { display: none; }
                .date-label {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 8px 10px;
                    border-radius: 25px;
                    cursor: pointer;
                    color: #333;
                    font-size: 15px;
                    transition: 0.2s;
                }
                .date-label .circle {
                    width: 18px;
                    height: 18px;
                    border: 1px solid #777;
                    border-radius: 50%;
                    margin-right: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: transparent;
                }
                .date-radio:checked + .date-label {
                    background-color: #4CAF50;
                    color: white;
                }
                .date-radio:checked + .date-label .circle {
                    border-color: white;
                }
                .date-radio:checked + .date-label .circle::after {
                    content: "";
                    width: 8px;
                    height: 8px;
                    background: white;
                    border-radius: 50%;
                }
                .date-radio:disabled + .date-label {
                    opacity: 0.4;
                    cursor: not-allowed;
                }
                
                .legend {
                    display: flex;
                    justify-content: center;
                    gap: 40px;
                    font-weight: bold;
                    font-size: 14px;
                    margin-bottom: 30px;
                }
                .legend-item { display: flex; align-items: center; gap: 8px; color: #555; }
                .dot-green { width: 14px; height: 14px; background: #4CAF50; border-radius: 50%; }
                .dot-red { width: 14px; height: 14px; background: #F44336; border-radius: 50%; }
                
                hr.divider {
                    margin: 0 20px 20px;
                    border-color: #eee;
                }
                
                .summary-box {
                    border: 1px solid #ddd;
                    border-radius: 8px;
                    padding: 15px 20px;
                    max-width: 350px;
                    margin: 0 auto 20px;
                    background: #f9f9f9;
                }
                .summary-item {
                    display: flex;
                    align-items: center;
                    margin-bottom: 12px;
                    font-size: 15px;
                    color: #333;
                }
                .summary-item:last-child { margin-bottom: 0; }
                .summary-item i { width: 25px; color: #666; font-size: 16px; text-align: center; margin-right: 5px; }
                
                .btn-book {
                    background: linear-gradient(to bottom, #ff8c00, #e65c00);
                    color: white;
                    font-weight: bold;
                    font-size: 18px;
                    border: none;
                    border-radius: 6px;
                    padding: 12px;
                    width: 100%;
                    max-width: 350px;
                    display: block;
                    margin: 0 auto 10px;
                    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                }
                .btn-book:hover {
                    background: linear-gradient(to bottom, #ffa500, #ff7f00);
                    color: white;
                }
            </style>
            
            <div id="wrap">
                <div class="container-fluid px-4 mt-5 mb-5">
                    
                    <h1 class="text-center mb-4"><t t-esc="package.name"/></h1>
                    
                    <div class="tour-card-container mb-4">
                        <div class="tour-card p-0 overflow-hidden">
                            <div class="row g-0 align-items-stretch">
                                <!-- Left Column: Image -->
                                <div class="col-md-5 col-lg-6">
                                    <div class="collage-main m-0" t-if="package.image" style="height: 350px; border-radius: 0;">
                                        <img t-attf-src="data:image/png;base64,#{package.image}" alt="Tour Main Image" 
                                             class="gallery-thumbnail" 
                                             style="cursor: pointer; width: 100%; height: 100%; object-fit: cover; border-radius: 0;"
                                             data-bs-toggle="modal" data-bs-target="#imageModal"
                                             t-attf-data-image-src="data:image/png;base64,#{package.image}"/>
                                    </div>
                                </div>
                                
                                <!-- Right Column: Description -->
                                <div class="col-md-7 col-lg-6" t-if="package.description">
                                    <div class="p-4 h-100 overflow-auto" style="max-height: 450px;">
                                        <h3 class="border-bottom pb-2 mb-3">Tour Description</h3>
                                        <div t-raw="package.description"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="tour-card-container mt-4" t-if="package.embed_video_url">
                        <div class="tour-card p-4">
                            <h3 class="border-bottom pb-2 mb-3">Tour Video</h3>
                            <div class="ratio ratio-16x9">
                                <iframe t-att-src="package.embed_video_url + '?autoplay=1&amp;mute=1'" allow="autoplay; encrypted-media" allowfullscreen="1" frameborder="0" style="width: 100%; min-height: 350px;"></iframe>
                            </div>
                        </div>
                    </div>
                    
                    <div class="tour-card-container mt-4" t-if="package.image_ids">
                        <div class="tour-card p-4">
                            <h3 class="border-bottom pb-2 mb-3">Photo Gallery</h3>
                            <div class="row g-2">
                                <t t-foreach="package.image_ids" t-as="img">
                                    <div class="col-6 col-md-4">
                                        <img t-attf-src="/web/image/#{img.id}" alt="Gallery Image" 
                                             class="img-fluid rounded gallery-thumbnail shadow-sm" 
                                             style="cursor: pointer; object-fit: cover; height: 150px; width: 100%;"
                                             data-bs-toggle="modal" data-bs-target="#imageModal"
                                             t-attf-data-image-src="/web/image/#{img.id}"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Booking Section -->
                    <div class="tour-card-container mt-4 mb-5">
                        <div class="tour-card p-4">
                            <t t-if="request.params.get('error') == 'unavailable'">
                                <div class="alert alert-danger mx-3 mt-3">
                                    The selected date does not have enough available seats.
                                </div>
                            </t>

                            <form action="/packages/book/confirm" method="post" t-if="calendars" id="booking_form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                
                                <h3 class="border-bottom pb-2 mb-3">Book Your Tour</h3>
                                <h4 class="section-title mt-2">Select Your Travel Date:</h4>
                                
                                <div class="date-grid">
                                    <t t-foreach="calendars" t-as="cal">
                                        <div class="date-option">
                                            <input type="radio" name="calendar_id" t-att-id="'cal_%s' % cal.id" t-att-value="cal.id" class="date-radio" t-att-disabled="cal.remaining_seats &lt;= 0" required="1" t-att-data-display="cal.date_start.strftime('%B %d') + ' - ' + cal.date_end.strftime('%d, %Y')" t-att-data-remaining-seats="cal.remaining_seats" t-att-data-total-seats="cal.available_seats" t-att-data-booked-seats="cal.booked_seats"/>
                                            <label t-att-for="'cal_%s' % cal.id" class="date-label">
                                                <span class="circle"></span>
                                                <t t-esc="cal.date_start.strftime('%B %d')"/> - <t t-esc="cal.date_end.strftime('%d')"/>
                                            </label>
                                        </div>
                                    </t>
                                </div>
                                
                                <div class="legend">
                                    <div class="legend-item"><span class="dot-green"></span> <span class="text-success">Available Date</span></div>
                                    <div class="legend-item"><span class="dot-red"></span> <span class="text-danger">Fully Booked</span></div>
                                </div>
                                
                                <hr class="divider"/>
                                
                                <div class="summary-box">
                                    <div class="summary-item">
                                        <i class="fa fa-calendar-o"></i> 
                                        <span>Date: <span id="display_date">Select a date</span></span>
                                    </div>
                                    <div class="summary-item">
                                        <i class="fa fa-clock-o"></i> 
                                        <span>Duration: <t t-esc="package.duration or 0"/> Days / <t t-esc="(package.duration or 1) - 1"/> Nights</span>
                                    </div>
                                    <div class="summary-item">
                                        <i class="fa fa-tag"></i> 
                                        <span>Price: <t t-esc="package.price" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/> per person</span>
                                    </div>
                                    <div class="summary-item mt-2">
                                        <i class="fa fa-users"></i> 
                                        <div class="d-flex align-items-center w-100">
                                            <span class="me-3">Seats:</span>
                                            <input type="number" name="seats" id="seat_input" value="1" min="1" class="form-control text-center p-1" style="width: 80px;"/>
                                            <span class="ms-3 text-muted small" id="max_seats_display"></span>
                                        </div>
                                    </div>
                                    <div class="summary-item mt-3 pt-3 border-top">
                                        <i class="fa fa-calculator"></i> 
                                        <span class="fs-5">Total Price: <strong id="total_price_display" class="text-primary" t-att-data-unit-price="package.price" t-att-data-currency-symbol="res_company.currency_id.symbol" t-att-data-currency-position="res_company.currency_id.position">
                                            <t t-esc="package.price" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                        </strong></span>
                                    </div>
                                </div>
                                
                                <button type="submit" class="btn btn-book">Confirm &amp; Book Now</button>
                            </form>
                            
                            <div t-else="" class="alert alert-warning mt-4 mx-3">
                                No upcoming dates available for this tour.
                            </div>
                        </div>
                    </div>
                    
                    <!-- Image Modal -->
                    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content bg-transparent border-0 shadow-none">
                                <div class="modal-header border-0 pb-0 justify-content-end">
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="background-color: white; padding: 10px; border-radius: 50%; opacity: 0.8;"></button>
                                </div>
                                <div class="modal-body text-center p-0 position-relative">
                                    <button type="button" class="btn btn-light position-absolute top-50 start-0 translate-middle-y ms-3" id="prevImageBtn" style="border-radius: 50%; width: 40px; height: 40px; padding: 0; box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 1055;">
                                        <i class="fa fa-chevron-left"></i>
                                    </button>
                                    <img src="" id="modalImage" class="img-fluid rounded shadow" alt="Large view" style="max-height: 80vh;"/>
                                    <button type="button" class="btn btn-light position-absolute top-50 end-0 translate-middle-y me-3" id="nextImageBtn" style="border-radius: 50%; width: 40px; height: 40px; padding: 0; box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 1055;">
                                        <i class="fa fa-chevron-right"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
                
                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        const radios = document.querySelectorAll('.date-radio');
                        const displayDate = document.getElementById('display_date');
                        const seatInputEl = document.getElementById('seat_input');
                        
                        radios.forEach(r => {
                            r.addEventListener('change', function() {
                                if(this.checked) {
                                    displayDate.textContent = this.getAttribute('data-display');
                                    if (seatInputEl) {
                                        let maxSeats = parseInt(this.getAttribute('data-remaining-seats'));
                                        let totalSeats = parseInt(this.getAttribute('data-total-seats'));
                                        let bookedSeats = parseInt(this.getAttribute('data-booked-seats'));
                                        seatInputEl.setAttribute('max', maxSeats);
                                        
                                        const maxSeatsDisplay = document.getElementById('max_seats_display');
                                        if (maxSeatsDisplay) {
                                            maxSeatsDisplay.textContent = '(Booked: ' + bookedSeats + ' | Remaining: ' + maxSeats + ' | Total: ' + totalSeats + ' seats)';
                                        }
                                        
                                        let currentSeats = parseInt(seatInputEl.value);
                                        currentSeats = Math.max(1, currentSeats || 1);
                                        if (currentSeats !== Math.min(currentSeats, maxSeats)) {
                                            seatInputEl.value = maxSeats;
                                            seatInputEl.dispatchEvent(new Event('input'));
                                        }
                                    }
                                }
                            });
                        });
                        
                        const firstAvailable = document.querySelector('.date-radio:not([disabled])');
                        if (firstAvailable) {
                            firstAvailable.checked = true;
                            firstAvailable.dispatchEvent(new Event('change'));
                        }
                        
                        // Image Modal logic
                        const galleryThumbnails = Array.from(document.querySelectorAll('.gallery-thumbnail'));
                        const modalImage = document.getElementById('modalImage');
                        let currentImageIndex = 0;

                        function updateModalImage(index) {
                            if (galleryThumbnails.length === 0) return;
                            if (index === -1) index = galleryThumbnails.length - 1;
                            if (index === galleryThumbnails.length) index = 0;
                            currentImageIndex = index;
                            modalImage.src = galleryThumbnails[index].getAttribute('data-image-src');
                        }

                        galleryThumbnails.forEach((thumb, index) => {
                            thumb.addEventListener('click', function() {
                                updateModalImage(index);
                            });
                        });
                        
                        const prevBtn = document.getElementById('prevImageBtn');
                        const nextBtn = document.getElementById('nextImageBtn');
                        
                        if (prevBtn) {
                            prevBtn.addEventListener('click', () => updateModalImage(currentImageIndex - 1));
                        }
                        if (nextBtn) {
                            nextBtn.addEventListener('click', () => updateModalImage(currentImageIndex + 1));
                        }
                        
                        document.addEventListener('keydown', function(e) {
                            if (document.body.classList.contains('modal-open')) {
                                if (e.key === 'ArrowLeft') {
                                    updateModalImage(currentImageIndex - 1);
                                } else if (e.key === 'ArrowRight') {
                                    updateModalImage(currentImageIndex + 1);
                                }
                            }
                        });
                        
                        // Seat Price Calculation
                        const seatInput = document.getElementById('seat_input');
                        const priceDisplay = document.getElementById('total_price_display');
                        if (seatInput &amp;&amp; priceDisplay) {
                            seatInput.addEventListener('input', function() {
                                let seats = parseInt(this.value);
                                seats = Math.max(1, seats || 1); // Avoid XML less-than signs
                                let maxSeats = parseInt(this.getAttribute('max'));
                                if (!isNaN(maxSeats)) {
                                    seats = Math.min(seats, maxSeats);
                                    this.value = seats;
                                }
                                
                                let unitPrice = parseFloat(priceDisplay.getAttribute('data-unit-price'));
                                let symbol = priceDisplay.getAttribute('data-currency-symbol');
                                let position = priceDisplay.getAttribute('data-currency-position');
                                
                                let total = (unitPrice * seats).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
                                
                                if (position === 'after') {
                                    priceDisplay.textContent = total + ' ' + symbol;
                                } else {
                                    priceDisplay.textContent = symbol + total;
                                }
                            });
                        }
                    });
                </script>
            </div>
        </t>
    </template>

    <template id="portal_my_bookings" name="My Bookings">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Bookings</t>
            </t>
            <t t-if="not bookings">
                <p class="alert alert-warning mt-4">You don't have any tour bookings yet.</p>
            </t>
            <t t-if="bookings" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>Booking Ref</th>
                        <th>Tour Package</th>
                        <th>Date</th>
                        <th>Seats</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="bookings" t-as="booking">
                        <tr>
                            <td><a t-attf-href="/my/bookings/#{booking.id}"><t t-esc="booking.name"/></a></td>
                            <td><t t-esc="booking.package_id.name"/></td>
                            <td><t t-esc="booking.calendar_id.date_start"/></td>
                            <td><t t-esc="booking.seats"/></td>
                            <td>
                                <span t-attf-class="badge rounded-pill #{'bg-success' if booking.state == 'confirmed' else 'bg-info' if booking.state == 'draft' else 'bg-danger'}">
                                    <t t-esc="dict(booking.fields_get(allfields=['state'])['state']['selection'])[booking.state]"/>
                                </span>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_booking_detail" name="Booking Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <div class="card mt-4">
                <div class="card-header bg-white">
                    <div class="row align-items-center">
                        <div class="col-lg-6">
                            <h4>Booking <span t-esc="booking.name"/></h4>
                        </div>
                        <div class="col-lg-6 text-end">
                            <span t-attf-class="badge #{'bg-success' if booking.state == 'confirmed' else 'bg-info' if booking.state == 'draft' else 'bg-danger'}">
                                <t t-esc="dict(booking.fields_get(allfields=['state'])['state']['selection'])[booking.state]"/>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <strong>Tour Package:</strong> <span t-esc="booking.package_id.name"/><br/>
                            <strong>Start Date:</strong> <span t-esc="booking.calendar_id.date_start"/><br/>
                            <strong>End Date:</strong> <span t-esc="booking.calendar_id.date_end"/><br/>
                        </div>
                        <div class="col-md-6 mb-4">
                            <strong>Number of Seats:</strong> <span t-esc="booking.seats"/><br/>
                            <strong>Total Price:</strong> <span t-esc="booking.total_price" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/><br/>
                        </div>
                    </div>
                    <t t-if="booking.state == 'draft'">
                        <div class="alert alert-info mt-3">
                            Your booking is currently in draft state. It will be confirmed by an administrator soon.
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- Add Bookings to Portal Home -->
    <template id="portal_my_home_menu_tour" name="Portal layout : tour entries" inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'booking'" t-attf-class="breadcrumb-item #{'active ' if not booking else ''}">
                <a t-if="booking" t-attf-href="/my/bookings?{{ keep_query() }}">Bookings</a>
                <t t-else="">Bookings</t>
            </li>
            <li t-if="booking" class="breadcrumb-item active">
                <t t-esc="booking.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_tour" name="Show Bookings" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Tour Bookings</t>
                <t t-set="url" t-value="'/my/bookings'"/>
                <t t-set="placeholder_count" t-value="'booking_count'"/>
            </t>
        </xpath>
    </template>
</odoo>
