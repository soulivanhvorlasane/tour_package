<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top Menu Item -->
    <menuitem id="menu_tour_root" name="Tour Packages" sequence="10" web_icon="tour_package,static/description/icon.png"/>

    <!-- Sub Menu Items -->
    <menuitem id="menu_tour_management" name="Tours" parent="menu_tour_root" sequence="10"/>
    <menuitem id="menu_tour_bookings" name="Bookings" parent="menu_tour_root" sequence="20"/>

    <!-- Actions -->
    <menuitem id="menu_tour_package_action" name="Packages" parent="menu_tour_management" action="action_tour_package" sequence="10"/>
    <menuitem id="menu_tour_calendar_action" name="Calendar" parent="menu_tour_management" action="action_tour_calendar" sequence="20"/>
    <menuitem id="menu_tour_booking_action" name="All Bookings" parent="menu_tour_bookings" action="action_tour_booking" sequence="10"/>

    <menuitem id="menu_tour_package_website"
              name="Tour Packages"
              parent="website.menu_website_configuration"
              action="action_tour_package"/>

    <!-- Action for Products (Services) -->
    <record id="action_tour_package_products" model="ir.actions.act_window">
        <field name="name">Products (Services)</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'service')]</field>
        <field name="context">{'default_type': 'service'}</field>
    </record>

    <!-- Configuration Menu -->
    <menuitem id="menu_tour_configuration" name="Configuration" parent="menu_tour_root" sequence="100"/>
    <menuitem id="menu_tour_products" name="Products" parent="menu_tour_configuration" action="action_tour_package_products" sequence="10"/>
</odoo>
