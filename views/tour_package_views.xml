<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tour_package_form" model="ir.ui.view">
        <field name="name">tour.package.form</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <form string="Tour Package">
                <sheet>
                    <field name="cover_image" widget="image" class="oe_avatar" options="{'preview_image': 'cover_image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Package Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="price"/>
                            <field name="duration"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="availability_status"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Included Products" name="products">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </list>
                            </field>
                            <group col="12" class="oe_invoice_lines_tab">
                                <group colspan="8">
                                    <field name="terms_and_conditions" nolabel="1" placeholder="Terms and conditions..."/>
                                </group>
                                <group colspan="4">
                                    <group class="oe_subtotal_footer">
                                        <field name="untaxed_amount" readonly="1"/>
                                        <field name="tax_amount" readonly="1"/>
                                        <field name="total_amount" class="oe_subtotal_footer_separator" readonly="1"/>
                                    </group>
                                </group>
                            </group>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Availabilities" name="calendar">
                            <field name="calendar_ids">
                                <list string="Calendar" editable="bottom">
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="available_seats"/>
                                    <field name="booked_seats"/>
                                    <field name="remaining_seats"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Media &amp; Gallery" name="media">
                            <group>
                                <field name="video_url" placeholder="e.g. https://www.youtube.com/watch?v=..." widget="url"/>
                                <field name="embed_video_url" invisible="1"/>
                            </group>
                            <group string="Gallery (Max 5 Images)">
                                <div colspan="2" class="text-muted mb-2">
                                    <i>Upload up to 5 images here. The images will be displayed in the gallery preview automatically.</i>
                                </div>
                                <field name="image_ids" widget="many2many_binary" options="{'accepted_file_extensions': 'image/*'}" nolabel="1" colspan="2"/>
                            </group>
                            <group string="Gallery Preview">
                                <field name="preview_html" widget="html" nolabel="1" readonly="1" colspan="2" options="{'sanitize': False}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tour_package_list" model="ir.ui.view">
        <field name="name">tour.package.list</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <list string="Tour Packages">
                <field name="name"/>
                <field name="category_id"/>
                <field name="description"/>
                <field name="price"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration"/>
                <field name="availability_status"/>
            </list>
        </field>
    </record>

    <record id="view_tour_package_search" model="ir.ui.view">
        <field name="name">tour.package.search</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <search string="Tour Packages">
                <field name="name"/>
                <field name="category_id"/>
                <field name="start_date"/>
                
                <filter name="filter_upcoming" string="Upcoming Tours" domain="[('start_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>

                <group expand="0" string="Group By">
                    <filter name="group_by_category" string="Category" context="{'group_by':'category_id'}"/>
                    <filter name="group_by_start_date" string="Start Date" context="{'group_by':'start_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_tour_package_calendar" model="ir.ui.view">
        <field name="name">tour.package.calendar</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <calendar string="Tour Packages" date_start="start_date" date_stop="end_date" color="category_id" mode="month">
                <field name="name"/>
                <field name="category_id"/>
                <field name="price"/>
            </calendar>
        </field>
    </record>

    <record id="action_tour_package" model="ir.actions.act_window">
        <field name="name">Tour Packages</field>
        <field name="res_model">tour.package</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tour package!
            </p>
        </field>
    </record>
</odoo>
