<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tour_demo_wizard_form" model="ir.ui.view">
        <field name="name">tour.demo.wizard.form</field>
        <field name="model">tour.demo.wizard</field>
        <field name="arch" type="xml">
            <form string="Manage Demo Data">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Use this wizard to load or remove the sample tour packages and calendars.
                    </div>
                    <footer>
                        <button name="action_load_demo_data" string="Load Demo Data" type="object" class="btn-primary"/>
                        <button name="action_remove_demo_data" string="Remove Demo Data" type="object" class="btn-danger"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tour_demo_wizard" model="ir.actions.act_window">
        <field name="name">Manage Demo Data</field>
        <field name="res_model">tour.demo.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
