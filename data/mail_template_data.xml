<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Confirmation Email Template -->
        <record id="email_template_tour_booking_confirmed" model="mail.template">
            <field name="name">Tour Booking: Confirmation</field>
            <field name="model_id" ref="tour_package.model_tour_booking"/>
            <field name="subject">Your Tour Booking Confirmation (Ref {{ object.name }})</field>
            <field name="email_to">{{ object.partner_id.email_formatted }}</field>
            <field name="description">Sent to customers when their tour booking is confirmed</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear <t t-out="object.partner_id.name or 'Customer'"></t>,<br/><br/>
        We are pleased to confirm your booking <strong><t t-out="object.name"></t></strong> for the tour package <strong><t t-out="object.package_id.name"></t></strong>.<br/><br/>
        <strong>Booking Details:</strong><br/>
        - Tour Dates: <t t-out="object.calendar_id.date_start"></t> to <t t-out="object.calendar_id.date_end"></t><br/>
        - Number of Seats: <t t-out="object.seats"></t><br/>
        - Total Price: <t t-out="format_amount(object.total_price, object.env.company.currency_id)"></t><br/>
        <br/>
        Thank you for booking with us!<br/>
        Best regards,<br/>
        <t t-out="object.env.company.name"></t>
    </p>
</div>
            </field>
        </record>

        <!-- Cancellation Email Template -->
        <record id="email_template_tour_booking_cancelled" model="mail.template">
            <field name="name">Tour Booking: Cancellation</field>
            <field name="model_id" ref="tour_package.model_tour_booking"/>
            <field name="subject">Your Tour Booking has been Cancelled (Ref {{ object.name }})</field>
            <field name="email_to">{{ object.partner_id.email_formatted }}</field>
            <field name="description">Sent to customers when their tour booking is cancelled</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear <t t-out="object.partner_id.name or 'Customer'"></t>,<br/><br/>
        We regret to inform you that your booking <strong><t t-out="object.name"></t></strong> for the tour package <strong><t t-out="object.package_id.name"></t></strong> has been cancelled.<br/><br/>
        If you have any questions, please contact us.<br/>
        <br/>
        Best regards,<br/>
        <t t-out="object.env.company.name"></t>
    </p>
</div>
            </field>
        </record>
    </data>
</odoo>
