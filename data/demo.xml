<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Demo Products for Fees -->
  <record id="demo_product_car_fee" model="product.product">
    <field name="name">Car Fee</field>
    <field name="type">service</field>
    <field name="list_price">100.0</field>
  </record>
  
  <record id="demo_product_room_fee" model="product.product">
    <field name="name">Room Fee</field>
    <field name="type">service</field>
    <field name="list_price">500.0</field>
  </record>

  <record id="demo_product_travel_fee" model="product.product">
    <field name="name">Travel Fee</field>
    <field name="type">service</field>
    <field name="list_price">600.0</field>
  </record>

  <record id="tour_package_demo1" model="tour.package">
    <field name="name">Laos Adventure</field>
    <field name="description">Explore Vientiane and Luang Prabang</field>
    <field name="price">500</field>
    <field name="is_demo" eval="True"/>
    <field name="line_ids" eval="[
      (0, 0, {'product_id': ref('demo_product_car_fee'), 'name': 'Car Fee', 'quantity': 1, 'price_unit': 100}),
      (0, 0, {'product_id': ref('demo_product_room_fee'), 'name': 'Room Fee', 'quantity': 1, 'price_unit': 500}),
      (0, 0, {'product_id': ref('demo_product_travel_fee'), 'name': 'Travel Fee', 'quantity': 1, 'price_unit': 600})
    ]"/>
  </record>
  <record id="tour_package_demo2" model="tour.package">
    <field name="name">Mekong Cruise</field>
    <field name="description">Relax on the Mekong River</field>
    <field name="price">800</field>
    <field name="is_demo" eval="True"/>
  </record>
  <record id="tour_package_demo3" model="tour.package">
    <field name="name">Mountain Trek</field>
    <field name="description">Hike through northern Laos</field>
    <field name="price">600</field>
    <field name="is_demo" eval="True"/>
  </record>
  
  <record id="demo_calendar_laos_1" model="tour.calendar">
        <field name="package_id" ref="tour_package_demo1"/>
        <field name="date_start" eval="(datetime.date.today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d')"/>
        <field name="date_end" eval="(datetime.date.today() + datetime.timedelta(days=14)).strftime('%Y-%m-%d')"/>
        <field name="available_seats">20</field>
        <field name="state">open</field>
        <field name="is_demo" eval="True"/>
  </record>

  <record id="demo_calendar_mekong_1" model="tour.calendar">
        <field name="package_id" ref="tour_package_demo2"/>
        <field name="date_start" eval="(datetime.date.today() + datetime.timedelta(days=10)).strftime('%Y-%m-%d')"/>
        <field name="date_end" eval="(datetime.date.today() + datetime.timedelta(days=15)).strftime('%Y-%m-%d')"/>
        <field name="available_seats">15</field>
        <field name="state">open</field>
        <field name="is_demo" eval="True"/>
  </record>

  <record id="demo_calendar_mountain_1" model="tour.calendar">
        <field name="package_id" ref="tour_package_demo3"/>
        <field name="date_start" eval="(datetime.date.today() + datetime.timedelta(days=5)).strftime('%Y-%m-%d')"/>
        <field name="date_end" eval="(datetime.date.today() + datetime.timedelta(days=12)).strftime('%Y-%m-%d')"/>
        <field name="available_seats">10</field>
        <field name="state">open</field>
        <field name="is_demo" eval="True"/>
  </record>
</odoo>
