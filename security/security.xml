<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_tour_package" model="ir.module.category">
            <field name="name">Tour Packages</field>
            <field name="description">Helps you handle your tour packages and bookings.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_tour_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_tour_package"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_tour_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_tour_package"/>
            <field name="implied_ids" eval="[(4, ref('group_tour_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record rules -->
        <record id="tour_booking_personal_rule" model="ir.rule">
            <field name="name">Personal Bookings</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal')), (4, ref('group_tour_user'))]"/>
        </record>

        <record id="tour_booking_admin_rule" model="ir.rule">
            <field name="name">All Bookings (Admin)</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tour_admin'))]"/>
        </record>
    </data>
</odoo>
